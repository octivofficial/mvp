{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MEM=/Users/octiv/.claude/projects/-Users-octiv-Octiv-MVP/memory/MEMORY.md; echo \"[Octiv] $(git -C /Users/octiv/Octiv_MVP log --oneline -1 2>/dev/null) | mem:$([ -f $MEM ] && wc -l < $MEM || echo '?')L\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | grep -q 'git commit' && { cd /Users/octiv/Octiv_MVP && echo '[PreCommit] Running tests...' && npm test 2>&1 | tail -5; } || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(~/.zshrc:*)"
    ]
  }
}
