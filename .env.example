# ─────────────────────────────────────────────────────────────
# Octiv MVP — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# NEVER commit real values. Copy to .env and fill in.
#   cp .env.example .env
#
# For secrets management, prefer:
#   op run -- npm start          (1Password CLI)
#   doppler run -- npm start     (Doppler)
#   infisical run -- npm start   (Infisical)
#
# Rotate all tokens every 60-90 days.
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
# Options: development | staging | production

# ── Minecraft / PaperMC ─────────────────────────────────────
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.21.11
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=

# ── Redis (Blackboard) ──────────────────────────────────────
BLACKBOARD_REDIS_URL=redis://localhost:6380
# Alternative host/port form (used by scripts/preflight.js):
# BLACKBOARD_REDIS_HOST=localhost
# BLACKBOARD_REDIS_PORT=6380
# Cluster mode (comma-separated nodes, overrides URL):
# REDIS_CLUSTER_NODES=host1:7000,host2:7001

# ── Obsidian Bridge ────────────────────────────────────────
# Local REST API plugin (HTTPS, port 27124 by default)
OBSIDIAN_API_KEY=
# OBSIDIAN_API_PORT=27124
# OBSIDIAN_VAULT_PATH=/path/to/vault  # default: cwd (path.resolve("."))

# ── Discord Bot ──────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STATUS_CHANNEL=
DISCORD_ALERTS_CHANNEL=
DISCORD_COMMANDS_CHANNEL=
DISCORD_CHAT_CHANNEL=
DISCORD_FORUM_CHANNEL=

# ── MCP: GitHub ──────────────────────────────────────────────
# Use fine-grained PAT scoped to octivofficial/mvp only
# Required scopes: contents:read, issues:write, pull_requests:write
GITHUB_TOKEN=

# ── MCP: Supabase ────────────────────────────────────────────
# Dev and Prod use separate project refs + tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Production overrides (only used when NODE_ENV=production)
SUPABASE_PROD_ACCESS_TOKEN=
SUPABASE_PROD_PROJECT_REF=

# ── App: Supabase (server-side writes) ───────────────────────
# Different from MCP token above — used by supabase-js client in app code
# anon key: public reads (dashboard)
# service_role key: bypasses RLS for server-side INSERT/UPDATE
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── MCP: Vercel ──────────────────────────────────────────────
# Scoped to octiv team only
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── MCP: Sentry ──────────────────────────────────────────────
# org-level auth token with project:read, event:read scopes
SENTRY_AUTH_TOKEN=
SENTRY_ORG=octiv
SENTRY_PROJECT=octiv-mvp

# ── MCP: Figma ───────────────────────────────────────────────
# Read-only personal access token
FIGMA_ACCESS_TOKEN=

# ── LLM (ReflexionEngine) ───────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
HUB_PRIMARY_MODEL=gemini-3-flash-preview

# ── Telegram Bot ─────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Public channel/group invite link (optional)
TELEGRAM_CHANNEL_URL=
# Comma-separated Telegram chat IDs allowed to use the bot
TELEGRAM_AUTHORIZED_USERS=
# ── OpenClaw / ClawHub (VM deployment)
# clawhub API token (run: clawhub login --token <token> OR set here for VM)
# CLAWHUB_TOKEN=clh_...
# openclaw config path override (default: ~/.openclaw/openclaw.json)
# OPENCLAW_CONFIG=/opt/octiv/.openclaw/openclaw.json
# OpenClaw proxy endpoint (optional, has default)
# OPENCLAW_ENDPOINT=https://api.dantelabs.com/openclaw/1.0
# Anthropic API key used by OpenClaw gateway (falls back to ANTHROPIC_API_KEY)
OPENCLAW_CLAUDE_API=

# ── Discord Voice (requires FFmpeg — disable on cloud VMs) ──
# Set to 'false' to silence FFmpeg errors in production
# DISCORD_VOICE_ENABLED=true

# ── LM Studio (Local LLM Fallback) ─────────────────────────
# Set to 'false' to disable LM Studio client entirely (e.g. cloud VM)
# LM_STUDIO_ENABLED=true
# Single URL (default: http://localhost:1234):
# LM_STUDIO_URL=http://localhost:1234
# Multi-URL failover (comma-separated):
# LM_STUDIO_URLS=http://localhost:1234,http://192.168.1.100:1234

# ── Optional Plugins (dormant by default) ─────────────────
# Set to 'true' to enable — these agents require external APIs or config
# ENABLE_CRAWLER=true
# ENABLE_WORKSPACE=true
# ENABLE_YOUTUBE=true
ENABLE_TELEGRAM_BOT=false

# ── Services ────────────────────────────────
DASHBOARD_PORT=3000
MCP_PORT=3001

# ── Logging ──────────────────────────────────
# LOG_LEVEL=info
# Options: debug | info | warn | error

# ─────────────────────────────────────────────────────────────
# Timeouts & Limits
# ─────────────────────────────────────────────────────────────
# All values in milliseconds unless noted. Defaults in config/timeouts.js.
# Uncomment to override.

# ── Core Bot Lifecycle ──────────────────────
# HEARTBEAT_INTERVAL_MS=10000
# SPAWN_TIMEOUT_MS=30000
# SPAWN_GROUND_WAIT_MS=2000

# ── Navigation & Movement ───────────────────
# PATHFINDER_TIMEOUT_MS=60000

# ── Deduplication & Cooldowns ───────────────
# EMERGENCY_DEDUP_MS=3000
# SAFETY_THREAT_COOLDOWN_MS=2000
# CHAT_COOLDOWN_MS=30000
# CONFESS_COOLDOWN_MS=300000

# ── VM Sandbox ──────────────────────────────
# VM_TIMEOUT_MS=3000

# ── Skill System ────────────────────────────
# SKILL_AUDIT_TIMEOUT_MS=5000

# ── Mining ──────────────────────────────────
# MINING_SESSION_TIMEOUT_MS=120000
# MINING_DIG_TIMEOUT_MS=5000
# MINING_NAV_TIMEOUT_MS=15000
# MINING_SMELT_TIMEOUT_MS=30000
# MINING_INVENTORY_THRESHOLD=32

# ── Farming ─────────────────────────────────
# FARMING_SESSION_TIMEOUT_MS=120000
# FARMING_NAV_TIMEOUT_MS=15000
# FARMING_INVENTORY_THRESHOLD=64

# ── Obsidian Bridge Timing ──────────────────
# OBSIDIAN_AGENT_DEBOUNCE_MS=3000
# OBSIDIAN_EVENT_FLUSH_MS=2000
# OBSIDIAN_HEARTBEAT_MS=10000
# OBSIDIAN_MAX_EVENTS=50
# OBSIDIAN_API_TIMEOUT_MS=5000

# ── LM Studio Timing ───────────────────────
# LM_STUDIO_HEALTH_CHECK_MS=2000
# LM_STUDIO_INFERENCE_TIMEOUT_MS=60000
# LM_STUDIO_HEALTH_INTERVAL_MS=30000
# LM_STUDIO_RETRY_DELAY_MS=1000

# ── Google Workspace Integration ──────────────────
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'
# GOOGLE_SHEET_ID=your_sheet_id_here
