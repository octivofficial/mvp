{
  "name": "octiv",
  "version": "1.0.0",
  "description": "Octiv — AI Agent Sandbox powered by OpenClaw + PaperMC",
  "main": "index.js",
  "scripts": {
    "test": "node --test --test-force-exit --test-concurrency=1 test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-force-exit --test-concurrency=1 test/*.test.js",
    "test:bot": "node --test --test-force-exit test/bot.test.js",
    "test:blackboard": "node --test --test-force-exit test/blackboard.test.js",
    "server": "bash start-server.sh",
    "bot": "node --env-file-if-exists=.env agent/bot.js",
    "team": "node --env-file-if-exists=.env agent/team.js",
    "start": "node --env-file-if-exists=.env start.js",
    "redis:check": "redis-cli -p 6380 ping",
    "lint": "eslint agent/ test/",
    "preflight": "node scripts/preflight.js",
    "launch": "bash scripts/launch.sh",
    "status": "redis-cli hgetall octiv:team:status:latest 2>/dev/null || echo \"Redis key not set yet\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "minecraft-data": "^3.105.0",
    "mineflayer": "^4.35.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "node-edge-tts": "^1.2.10",
    "redis": "^5.11.0",
    "sodium-native": "^5.0.10",
    "vec3": "^0.1.10"
  },
  "optionalDependencies": {
    "discord.js": "^14.16.0",
    "groq-sdk": "^0.37.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.2"
  }
}
